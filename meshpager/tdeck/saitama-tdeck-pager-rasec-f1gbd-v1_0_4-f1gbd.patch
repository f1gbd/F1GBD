diff --git a/src/mesh/PagerRasec.cpp b/src/mesh/PagerRasec.cpp
new file mode 100644
index 0000000..ba49205
--- /dev/null
+++ b/src/mesh/PagerRasec.cpp
@@ -0,0 +1,165 @@
+// Saitama — PagerRasec.cpp
+// F1GBD — Portage de la fonction "RASEC ALERT" du MeshPager v5.0 vers le T-Deck.
+// Les analyseurs pagerMatchCode / pagerParsePass / pagerParseBeeps sont repris
+// tels quels du MeshPager (logique inchangée). Persistance via Preferences (NVS).
+
+#include "PagerRasec.h"
+#include <string.h>
+#include <stdlib.h>
+#include <Preferences.h>
+
+namespace ops {
+namespace pager {
+
+// ── État courant (chargé de la flash au begin()) ─────────────────────────────
+static char _code[PAGER_CODE_MAXLEN] = PAGER_ACTIVATION_CODE;
+static int  _beeps = 3;
+static volatile bool _alertPending = false;
+static volatile int  _pendingBeeps = 0;
+
+static const char* NVS_NS   = "rasec";
+static const char* K_CODE   = "code";
+static const char* K_BEEPS  = "beeps";
+
+// ── Analyseurs (portés à l'identique du MeshPager) ───────────────────────────
+
+// true si "text" déclenche l'alerte pour le code "code" ("#ra <code>").
+static bool matchCode(const char* text, const char* code) {
+    if (!text) return false;
+    while (*text == ' ') text++;                       // espaces de tête
+    size_t plen = strlen(PAGER_CMD_PREFIX);
+    if (strncmp(text, PAGER_CMD_PREFIX, plen) == 0) {
+        const char* p = text + plen;
+        while (*p == ' ') p++;                          // espace(s) avant le code
+        size_t clen = strlen(code);
+        if (clen > 0 && strncmp(p, code, clen) == 0
+            && (p[clen] == 0 || p[clen] == ' ' || p[clen] == '\r' || p[clen] == '\n')) {
+            return true;                                // "#ra <code>" valide
+        }
+        return false;                                  // préfixe présent mais code faux
+    }
+    return false;
+}
+
+// "#rapass <ancien> <nouveau>" : 1 si OK (-> new_buf), -1 si commande mais ancien
+// code faux / nouveau vide, 0 si ce n'est pas la commande.
+static int parsePass(const char* text, const char* code, char* new_buf, size_t new_max) {
+    if (!text) return 0;
+    while (*text == ' ') text++;
+    size_t pl = strlen(PAGER_PASS_PREFIX);
+    if (strncmp(text, PAGER_PASS_PREFIX, pl) != 0 || text[pl] != ' ') return 0;
+    const char* p = text + pl;
+    while (*p == ' ') p++;
+    size_t clen = strlen(code);
+    if (clen == 0 || strncmp(p, code, clen) != 0 || p[clen] != ' ') return -1;
+    p += clen;
+    while (*p == ' ') p++;
+    size_t n = 0;
+    while (p[n] && p[n] != ' ' && p[n] != '\r' && p[n] != '\n' && n < new_max - 1) {
+        new_buf[n] = p[n]; n++;
+    }
+    new_buf[n] = 0;
+    return (n > 0) ? 1 : -1;
+}
+
+// "#b <n>" -> *out = n (0..MAX). 1 si valide, -1 si commande mais valeur invalide,
+// 0 si autre commande.
+static int parseBeeps(const char* text, int* out) {
+    if (!text) return 0;
+    while (*text == ' ') text++;
+    size_t pl = strlen(PAGER_BEEP_PREFIX);
+    if (strncmp(text, PAGER_BEEP_PREFIX, pl) != 0 || text[pl] != ' ') return 0;
+    const char* p = text + pl;
+    while (*p == ' ') p++;
+    if (*p < '0' || *p > '9') return -1;
+    int n = atoi(p);
+    if (n < 0 || n > PAGER_BEEP_MAX) return -1;
+    *out = n;
+    return 1;
+}
+
+// ── Persistance ──────────────────────────────────────────────────────────────
+static void saveCode() {
+    Preferences p;
+    if (p.begin(NVS_NS, false)) { p.putString(K_CODE, _code); p.end(); }
+}
+static void saveBeeps() {
+    Preferences p;
+    if (p.begin(NVS_NS, false)) { p.putInt(K_BEEPS, _beeps); p.end(); }
+}
+
+void begin() {
+    Preferences p;
+    if (p.begin(NVS_NS, true)) {
+        String c = p.getString(K_CODE, PAGER_ACTIVATION_CODE);
+        strncpy(_code, c.c_str(), sizeof(_code) - 1);
+        _code[sizeof(_code) - 1] = 0;
+        int b = p.getInt(K_BEEPS, 3);
+        if (b >= 0 && b <= PAGER_BEEP_MAX) _beeps = b;
+        p.end();
+    }
+}
+
+const char* code()  { return _code; }
+int         beeps() { return _beeps; }
+
+// ── Analyse d'un message entrant ─────────────────────────────────────────────
+Result onIncoming(const char* text, bool isDirect) {
+    Result r;
+    if (!text) return r;
+
+    // Commandes de configuration : messages directs uniquement.
+    if (isDirect) {
+        char newcode[PAGER_CODE_MAXLEN];
+        int st = parsePass(text, _code, newcode, sizeof(newcode));
+        if (st != 0) {
+            if (st == 1) {
+                strncpy(_code, newcode, sizeof(_code) - 1);
+                _code[sizeof(_code) - 1] = 0;
+                saveCode();
+                r.action = Action::PassChanged;
+                strncpy(r.reply, PAGER_PASS_ACK, sizeof(r.reply) - 1);
+            } else {
+                r.action = Action::PassFail;
+                strncpy(r.reply, PAGER_PASS_FAIL, sizeof(r.reply) - 1);
+            }
+            return r;
+        }
+
+        int nb;
+        st = parseBeeps(text, &nb);
+        if (st != 0) {
+            if (st == 1) {
+                _beeps = nb;
+                saveBeeps();
+                r.action = Action::BeepsSet;
+                if (nb == 0)
+                    snprintf(r.reply, sizeof(r.reply), "Alarme continue (acquit. touche)");
+                else
+                    snprintf(r.reply, sizeof(r.reply), "Repetitions reglees sur %d", nb);
+            } else {
+                r.action = Action::BeepsFail;
+                snprintf(r.reply, sizeof(r.reply), "Valeur #b invalide (0-%d)", PAGER_BEEP_MAX);
+            }
+            return r;
+        }
+    }
+
+    // Déclencheur d'alerte (direct ET canal).
+    if (matchCode(text, _code)) {
+        r.action = Action::Alert;
+        r.beeps  = _beeps;
+        strncpy(r.reply, PAGER_ACK_TEXT, sizeof(r.reply) - 1);
+        return r;
+    }
+
+    return r;
+}
+
+// ── Pont UI ──────────────────────────────────────────────────────────────────
+void setAlertPending(int b) { _pendingBeeps = b; _alertPending = true; }
+bool alertPending()         { return _alertPending; }
+int  consumeAlertBeeps()    { _alertPending = false; return _pendingBeeps; }
+
+}  // namespace pager
+}  // namespace ops
diff --git a/src/mesh/PagerRasec.h b/src/mesh/PagerRasec.h
new file mode 100644
index 0000000..5345664
--- /dev/null
+++ b/src/mesh/PagerRasec.h
@@ -0,0 +1,94 @@
+// Saitama — PagerRasec.h
+// F1GBD — Portage de la fonction "RASEC ALERT" du MeshPager v5.0 vers le T-Deck.
+//
+// Fonction de messagerie d'alerte déclenchée par un message chat sur canal privé
+// ou en direct :
+//    "#ra <code>"              -> déclenche l'alerte (son redalert.mp3 + popup) + ACK
+//    "#rapass <ancien> <new>"  -> change le code d'activation (DM uniquement, persisté)
+//    "#b <n>"                  -> règle le nb de répétitions du son (0 = continu, DM only)
+//
+// Toute la logique d'analyse est portée à l'identique du MeshPager ; seule la
+// partie son diffère : le T-Deck n'a pas de piézo, on joue redalert.mp3 en I2S.
+//
+// Persistance : namespace NVS "rasec" (indépendant du blob de config Saitama).
+
+#pragma once
+#include <stdint.h>
+#include <stddef.h>
+
+// ── Constantes surchargeables via build_flags (-D...) ────────────────────────
+#ifndef PAGER_CMD_PREFIX
+  #define PAGER_CMD_PREFIX       "#ra"       // déclencheur d'alerte
+#endif
+#ifndef PAGER_PASS_PREFIX
+  #define PAGER_PASS_PREFIX      "#rapass"   // changement de code
+#endif
+#ifndef PAGER_BEEP_PREFIX
+  #define PAGER_BEEP_PREFIX      "#b"        // nb de répétitions
+#endif
+#ifndef PAGER_ACTIVATION_CODE
+  #define PAGER_ACTIVATION_CODE  "ADRASEC77" // code par défaut (build)
+#endif
+#ifndef PAGER_ACK_TEXT
+  #define PAGER_ACK_TEXT         "Pager OK - alerte bien recue"  // NE PAS contenir le code (anti-boucle)
+#endif
+#ifndef PAGER_PASS_ACK
+  #define PAGER_PASS_ACK         "Code RASEC mis a jour"
+#endif
+#ifndef PAGER_PASS_FAIL
+  #define PAGER_PASS_FAIL        "Echec: ancien code RASEC incorrect"
+#endif
+#ifndef PAGER_BEEP_MAX
+  #define PAGER_BEEP_MAX         20
+#endif
+#ifndef PAGER_ALERT_MP3
+  #define PAGER_ALERT_MP3        "/redalert.mp3"  // chemin SD du son d'alerte
+#endif
+#ifndef PAGER_CODE_MAXLEN
+  #define PAGER_CODE_MAXLEN      24
+#endif
+
+namespace ops {
+namespace pager {
+
+// Action à effectuer après analyse d'un message entrant.
+enum class Action : uint8_t {
+    None,         // rien à faire
+    Alert,        // déclencher l'alerte (son + popup) + renvoyer reply (ACK)
+    PassChanged,  // code changé -> renvoyer reply (PASS_ACK) — DM only
+    PassFail,     // #rapass mais ancien code faux -> renvoyer reply (PASS_FAIL)
+    BeepsSet,     // #b n appliqué -> renvoyer reply — DM only
+    BeepsFail,    // #b invalide -> renvoyer reply
+};
+
+struct Result {
+    Action action  = Action::None;
+    int    beeps   = 0;      // pour Alert : nb de répétitions (0 = continu jusqu'à acquittement)
+    char   reply[64] = {0};  // texte d'ACK à renvoyer (vide si aucun)
+};
+
+// Charge le code + le nb de bips persistés (à appeler une fois au démarrage,
+// après config::init()). Sans persistance, part sur PAGER_ACTIVATION_CODE.
+void begin();
+
+const char* code();   // code d'activation courant (ex. "ADRASEC77")
+int         beeps();  // nb de répétitions courant (0 = continu)
+
+// Analyse un message entrant.
+//   text     : corps du message. Pour un canal, le préfixe "Nom: " doit être
+//              retiré AVANT l'appel (voir point d'insertion onChannelMessageRecv).
+//   isDirect : true = message direct (autorise #rapass et #b),
+//              false = canal (seul #ra déclenche l'alerte).
+// Ne touche à aucune ressource matérielle : renvoie juste l'action à réaliser.
+Result onIncoming(const char* text, bool isDirect);
+
+// ── Pont vers l'UI (déclenchement du son + popup depuis le contexte UI) ──────
+// Les callbacks mesh tournent hors du thread LVGL : on ne joue donc PAS le son
+// ni le popup directement dans onIncoming(). Le callback pose un "drapeau"
+// d'alerte que la boucle UI consomme (comme pour les notifications Saitama).
+void setAlertPending(int beeps);   // appelé depuis le callback mesh
+bool alertPending();               // testé dans UIScreen::tick()
+int  consumeAlertBeeps();          // lit + efface le drapeau, renvoie le nb de répétitions
+
+}  // namespace pager
+}  // namespace ops
diff --git a/src/ui/RasecAlert.cpp b/src/ui/RasecAlert.cpp
new file mode 100644
index 0000000..272f1cd
--- /dev/null
+++ b/src/ui/RasecAlert.cpp
@@ -0,0 +1,139 @@
+// Saitama — RasecAlert.cpp
+// F1GBD — Écran plein écran "RASEC ALERT" clignotant. Voir RasecAlert.h.
+
+#include "RasecAlert.h"
+#include "Theme.h"
+#include "../hardware/Board.h"
+#include "../utils/MP3Player.h"
+#include "../utils/SDCard.h"
+#include "../utils/Log.h"
+#include "../mesh/PagerRasec.h"   // pour PAGER_ALERT_MP3
+#include <lvgl.h>
+#include <Arduino.h>
+
+namespace ops {
+namespace ui {
+namespace rasec {
+
+// ── État interne ─────────────────────────────────────────────────────────────
+static lv_obj_t*  s_overlay   = nullptr;   // conteneur plein écran
+static lv_obj_t*  s_title     = nullptr;   // "RASEC ALERT"
+static lv_obj_t*  s_counter   = nullptr;   // "Alertes recues: N"
+static uint32_t   s_count     = 0;         // compteur d'alertes
+static int        s_reps      = 0;         // répétitions restantes ; <0 = continu
+static bool       s_blinkOn   = false;
+static uint32_t   s_blinkMs   = 0;
+static const uint32_t BLINK_PERIOD_MS = 350;
+
+// ── Acquittement sur appui / tap ─────────────────────────────────────────────
+static void _onClick(lv_event_t* /*e*/) { dismiss(); }
+
+// ── Construction de l'overlay ────────────────────────────────────────────────
+static void _build() {
+    lv_obj_t* parent = lv_scr_act();
+    s_overlay = lv_obj_create(parent);
+    lv_obj_set_size(s_overlay, OPS_SCREEN_W, OPS_SCREEN_H);
+    lv_obj_align(s_overlay, LV_ALIGN_CENTER, 0, 0);
+    lv_obj_set_style_radius(s_overlay, 0, LV_PART_MAIN);
+    lv_obj_set_style_border_width(s_overlay, 0, LV_PART_MAIN);
+    lv_obj_set_style_pad_all(s_overlay, 0, LV_PART_MAIN);
+    lv_obj_set_style_bg_color(s_overlay, theme::RED, LV_PART_MAIN);
+    lv_obj_set_style_bg_opa(s_overlay, LV_OPA_COVER, LV_PART_MAIN);
+    lv_obj_clear_flag(s_overlay, LV_OBJ_FLAG_SCROLLABLE);
+    lv_obj_add_flag(s_overlay, LV_OBJ_FLAG_CLICKABLE);
+    lv_obj_add_event_cb(s_overlay, _onClick, LV_EVENT_CLICKED, nullptr);
+
+    s_title = lv_label_create(s_overlay);
+    lv_obj_set_style_text_font(s_title, &lv_font_montserrat_36, LV_PART_MAIN);
+    lv_obj_set_style_text_color(s_title, lv_color_white(), LV_PART_MAIN);
+    lv_label_set_text(s_title, "RASEC ALERT");
+    lv_obj_align(s_title, LV_ALIGN_CENTER, 0, -20);
+
+    s_counter = lv_label_create(s_overlay);
+    lv_obj_set_style_text_font(s_counter, &lv_font_montserrat_16, LV_PART_MAIN);
+    lv_obj_set_style_text_color(s_counter, lv_color_white(), LV_PART_MAIN);
+    lv_obj_align(s_counter, LV_ALIGN_CENTER, 0, 24);
+
+    lv_obj_t* hint = lv_label_create(s_overlay);
+    lv_obj_set_style_text_font(hint, &lv_font_montserrat_14, LV_PART_MAIN);
+    lv_obj_set_style_text_color(hint, lv_color_hex(0xFFDDDD), LV_PART_MAIN);
+    lv_label_set_text(hint, "Toucher l'ecran pour acquitter");
+    lv_obj_align(hint, LV_ALIGN_BOTTOM_MID, 0, -12);
+
+    lv_obj_move_foreground(s_overlay);
+}
+
+static void _refreshCounter() {
+    if (!s_counter) return;
+    char buf[32];
+    snprintf(buf, sizeof(buf), "Alertes recues: %lu", (unsigned long)s_count);
+    lv_label_set_text(s_counter, buf);
+}
+
+// ── API ──────────────────────────────────────────────────────────────────────
+void trigger(int beeps) {
+    s_count++;
+    s_reps    = (beeps == 0) ? -1 : beeps;   // 0 -> continu
+    s_blinkOn = true;
+    s_blinkMs = millis();
+
+    if (!s_overlay) _build();
+    _refreshCounter();
+    lv_obj_move_foreground(s_overlay);
+
+    // Rétroéclairage à fond.
+    Board::instance().setDisplayBrightness(255);
+
+    // Son : uniquement si la SD est montée ET le fichier présent. Sinon l'alerte
+    // reste visuelle (jamais de plantage si /redalert.mp3 manque).
+    bool haveSound = (ops::sdcard::isMounted() || ops::sdcard::tryMount())
+                     && ops::sdcard::hasFile(PAGER_ALERT_MP3);
+    if (haveSound) {
+        ops::mp3player::stop();
+        ops::mp3player::play(PAGER_ALERT_MP3);
+    } else {
+        s_reps = 0;   // pas de répétition son
+        OPS_LOG("RASEC", "Alerte visuelle seule: %s indisponible (SD ?)", PAGER_ALERT_MP3);
+    }
+    lv_refr_now(nullptr);
+}
+
+void tick() {
+    if (!s_overlay) return;
+
+    // Clignotement rouge <-> noir.
+    uint32_t now = millis();
+    if (now - s_blinkMs >= BLINK_PERIOD_MS) {
+        s_blinkMs = now;
+        s_blinkOn = !s_blinkOn;
+        lv_obj_set_style_bg_color(s_overlay,
+            s_blinkOn ? theme::RED : lv_color_black(), LV_PART_MAIN);
+    }
+
+    // Maintien du rétroéclairage (annule un éventuel dimming du même tick).
+    Board::instance().setDisplayBrightness(255);
+
+    // Répétition du son.
+    if (s_reps != 0 && ops::mp3player::state() == ops::mp3player::State::Done) {
+        if (s_reps > 0) s_reps--;
+        if (s_reps != 0) ops::mp3player::play(PAGER_ALERT_MP3);
+    }
+}
+
+void dismiss() {
+    ops::mp3player::stop();
+    s_reps = 0;
+    if (s_overlay) {
+        lv_obj_del(s_overlay);
+        s_overlay = nullptr;
+        s_title   = nullptr;
+        s_counter = nullptr;
+    }
+}
+
+bool     active() { return s_overlay != nullptr; }
+uint32_t count()  { return s_count; }
+
+}  // namespace rasec
+}  // namespace ui
+}  // namespace ops
diff --git a/src/ui/RasecAlert.h b/src/ui/RasecAlert.h
new file mode 100644
index 0000000..fb5dc21
--- /dev/null
+++ b/src/ui/RasecAlert.h
@@ -0,0 +1,32 @@
+// Saitama — RasecAlert.h
+// F1GBD — Écran plein écran "RASEC ALERT" clignotant (équivalent T-Deck de
+// l'alerte pager du MeshPager). Overlay LVGL autonome, thread UI uniquement.
+//
+//   - trigger(beeps) : affiche l'alerte plein écran (rouge/noir clignotant),
+//                      incrémente le compteur, lance /redalert.mp3.
+//                      beeps = nb de répétitions du son ; 0 = continu jusqu'à
+//                      acquittement (comme "#b 0" sur le MeshPager).
+//   - tick()         : à appeler à chaque UIScreen::tick() (gère clignotement,
+//                      répétition du son, maintien du rétroéclairage).
+//   - dismiss()      : acquittement (stoppe le son, ferme l'écran).
+//   - active()       : true tant que l'alerte est affichée.
+//
+// IMPORTANT : toutes ces fonctions doivent être appelées depuis le thread LVGL
+// (UIScreen::tick), jamais depuis un callback mesh.
+
+#pragma once
+#include <stdint.h>
+
