index 0000000..5ddce4c
--- /dev/null
+++ b/dashboard/static/js/rasec_alert.js
@@ -0,0 +1,246 @@
+// Ratspeak — RASEC-ALERT (F1GBD / ADRASEC 77)
+//
+// Équivalent web/Tauri de l'écran d'alerte pager du MeshPager / de l'édition
+// Saitama T-Deck. Le backend (crate ratspeak-runtime, module `rasec`) détecte
+// la commande « #ra <code> » dans un message LXMF entrant, renvoie l'ACK, puis
+// émet l'événement Tauri `rasec_alert`. Ce module :
+//   * affiche un overlay plein écran clignotant « RASEC ALERT » + un compteur ;
+//   * joue une sirène bitonale synthétisée en Web Audio (1000 / 750 Hz) ;
+//       - beeps > 0  : N cycles puis arrêt ;
+//       - beeps <= 0 : continu jusqu'à acquittement (comme « #b 0 ») ;
+//   * s'acquitte en touchant l'écran, en cliquant, ou avec Échap / Entrée /
+//     Espace (stoppe la sirène et ferme l'overlay).
+(function () {
+    'use strict';
+    window.RS = window.RS || {};
+
+    // ── Paramètres de la sirène (repris du two-tone T-Deck) ──────────────────
+    var TONE_A_HZ = 1000.0;
+    var TONE_B_HZ = 750.0;
+    var TONE_MS = 300;                 // durée de chaque demi-cycle
+    var CYCLE_MS = TONE_A_HZ ? (TONE_MS * 2) : 600; // 600 ms / cycle
+    var FADE_MS = 12;                  // court fondu anti-clic entre tonalités
+    var BLINK_PERIOD_MS = 350;
+
+    // ── État interne ─────────────────────────────────────────────────────────
+    var overlay = null;
+    var counterEl = null;
+    var alertCount = 0;
+    var blinkTimer = null;
+    var blinkOn = true;
+    var stopTimer = null;
+    var srcNode = null;
+    var gainNode = null;
+
+    function _ctx() {
+        if (window.RS.audioPlayback && typeof window.RS.audioPlayback.context === 'function') {
+            return window.RS.audioPlayback.context();
+        }
+        var ctor = window.AudioContext || window.webkitAudioContext || null;
+        if (!ctor) return null;
+        if (!window.__ratspeakFallbackAudioContext) {
+            try { window.__ratspeakFallbackAudioContext = new ctor(); } catch (_) { return null; }
+        }
+        return window.__ratspeakFallbackAudioContext;
+    }
+
+    function _ensureAudio() {
+        if (window.RS.audioPlayback && typeof window.RS.audioPlayback.ensure === 'function') {
+            return window.RS.audioPlayback.ensure({ installUnlock: true });
+        }
+        var ctx = _ctx();
+        if (!ctx) return Promise.resolve(false);
+        if (ctx.state === 'suspended' && typeof ctx.resume === 'function') {
+            return ctx.resume().then(function () { return true; }).catch(function () { return false; });
+        }
+        return Promise.resolve(true);
+    }
+
+    // Un cycle de sirène : tonalité A puis tonalité B, avec fondus courts.
+    function _renderCycle(ctx) {
+        var sampleRate = ctx.sampleRate || 44100;
+        var total = Math.max(1, Math.round((sampleRate * CYCLE_MS) / 1000));
+        var half = Math.round(total / 2);
+        var fade = Math.max(1, Math.round((sampleRate * FADE_MS) / 1000));
+        var buffer = ctx.createBuffer(1, total, sampleRate);
+        var out = buffer.getChannelData(0);
+        var phase = 0;
+        for (var i = 0; i < total; i++) {
+            var inSecond = i >= half;
+            var freq = inSecond ? TONE_B_HZ : TONE_A_HZ;
+            var local = inSecond ? i - half : i;
+            var segLen = inSecond ? (total - half) : half;
+            phase += (2 * Math.PI * freq) / sampleRate;
+            var env = 1.0;
+            if (local < fade) env = local / fade;
+            else if (local > segLen - fade) env = Math.max(0, (segLen - local) / fade);
+            out[i] = Math.sin(phase) * env * 0.5;
+        }
+        return buffer;
+    }
+
+    function _startSiren(beeps) {
+        _stopSiren();
+        _ensureAudio().then(function (ok) {
+            if (!ok || !overlay) return;
+            var ctx = _ctx();
+            if (!ctx) return;
+            try {
+                gainNode = ctx.createGain();
+                gainNode.gain.setValueAtTime(0.9, ctx.currentTime);
+                gainNode.connect(ctx.destination);
+                srcNode = ctx.createBufferSource();
+                srcNode.buffer = _renderCycle(ctx);
+                srcNode.loop = true;
+                srcNode.connect(gainNode);
+                srcNode.start(ctx.currentTime);
+                // beeps > 0 : arrêt automatique après N cycles.
+                if (beeps > 0) {
+                    stopTimer = setTimeout(function () { _stopSiren(); }, beeps * CYCLE_MS + 40);
+                }
+            } catch (err) {
+                if (window.RS.diag) window.RS.diag('warn', '[rasec] Web Audio siren failed:', err);
+            }
+        });
