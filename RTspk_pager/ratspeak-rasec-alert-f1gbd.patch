@@ -0,0 +1,321 @@
+//! Ratspeak — RASEC-ALERT (F1GBD / ADRASEC 77)
+//!
+//! Portage de la fonction « RASEC ALERT » du MeshPager / de l'édition Saitama
+//! T-Deck (MeshCore) et de rsDeck vers **Ratspeak** (Reticulum / LXMF, Rust +
+//! Tauri).
+//!
+//! Un message **LXMF** reçu dont le corps correspond au code d'activation
+//! déclenche une alerte dans l'interface (overlay plein écran clignotant
+//! « RASEC ALERT » + sirène bitonale synthétisée en Web Audio) et un **accusé
+//! de réception automatique** renvoyé à l'expéditeur.
+//!
+//! Sous Reticulum/LXMF, toute trame reçue est adressée directement à l'adresse
+//! LXMF du nœud : il n'y a pas de notion de « canal » comme sous MeshCore. Les
+//! trois commandes sont donc toujours autorisées (équivalent `isDirect = true`
+//! de la version Saitama) :
+//!
+//!   * `#ra <code>`             — déclenche l'alerte (overlay + sirène) + ACK.
+//!   * `#rapass <ancien> <new>` — change le code d'activation (persisté).
+//!   * `#b <n>`                 — règle le nombre de répétitions de la sirène
+//!                                (`0` = continu jusqu'à acquittement, 0–20).
+//!
+//! Les analyseurs `match_code` / `parse_pass` / `parse_beeps` reprennent à
+//! l'identique la logique du MeshPager (constantes et terminateurs inclus).
+//!
+//! Persistance : le code et le nombre de répétitions sont stockés dans la table
+//! `settings` de la base Ratspeak (clés `rasec_code` / `rasec_beeps`), ce qui
+//! joue le rôle du namespace NVS `rasec` de la version T-Deck.
+
+use std::sync::Arc;
+
+use crate::db;
+use crate::state::AppState;
+use serde_json::json;
+
+// ── Constantes (équivalent des `#define` surchargeables de PagerRasec.h) ─────
+/// Code d'activation par défaut (première utilisation, avant persistance).
+pub const DEFAULT_CODE: &str = "ADRASEC77";
+/// Nombre de répétitions par défaut de la sirène.
+pub const DEFAULT_BEEPS: i64 = 3;
+/// Plage maximale du réglage `#b`.
+pub const BEEP_MAX: i64 = 20;
+/// Longueur maximale (caractères) du code d'activation.
+pub const CODE_MAXLEN: usize = 23;
+/// Marqueur de version de l'option (surfacé dans l'événement `rasec_alert`).
+pub const RASEC_ALERT_VERSION: &str = "rasec-f1gbd-1";
+
+const CMD_PREFIX: &str = "#ra"; // déclencheur d'alerte
+const PASS_PREFIX: &str = "#rapass"; // changement de code
+const BEEP_PREFIX: &str = "#b"; // nb de répétitions
+
+// L'ACK ne doit JAMAIS contenir le code (anti-boucle d'auto-déclenchement).
+const ACK_TEXT: &str = "Pager OK - alerte bien recue";
+const PASS_ACK: &str = "Code RASEC mis a jour";
+const PASS_FAIL: &str = "Echec: ancien code RASEC incorrect";
+
+const K_CODE: &str = "rasec_code";
+const K_BEEPS: &str = "rasec_beeps";
+
+// ── Analyseurs (portés à l'identique du MeshPager) ──────────────────────────
+
+/// `true` si `text` déclenche l'alerte pour `code` (« #ra <code> »).
+/// Le caractère suivant le code doit être une fin de chaîne, un espace ou un
+/// retour chariot/ligne (comme dans la version C).
+pub fn match_code(text: &str, code: &str) -> bool {
+    let t = text.trim_start_matches(' ');
+    let Some(rest) = t.strip_prefix(CMD_PREFIX) else {
+        return false;
+    };
+    let rest = rest.trim_start_matches(' ');
+    if code.is_empty() {
+        return false;
+    }
+    let Some(after) = rest.strip_prefix(code) else {
+        return false;
+    };
+    matches!(after.chars().next(), None | Some(' ') | Some('\r') | Some('\n'))
+}
+
+/// Résultat de l'analyse de « #rapass <ancien> <nouveau> ».
+#[derive(Debug, PartialEq, Eq)]
+pub enum PassResult {
+    /// Ce n'est pas la commande `#rapass`.
+    NotCommand,
+    /// Commande `#rapass` mais ancien code faux / nouveau code vide.
+    Invalid,
+    /// Nouveau code accepté.
+    Ok(String),
+}
+
+/// Analyse « #rapass <ancien> <nouveau> ».
+pub fn parse_pass(text: &str, code: &str) -> PassResult {
+    let t = text.trim_start_matches(' ');
+    let Some(rest) = t.strip_prefix(PASS_PREFIX) else {
+        return PassResult::NotCommand;
+    };
+    // Un espace doit suivre immédiatement le préfixe (text[pl] == ' ').
+    if !rest.starts_with(' ') {
+        return PassResult::NotCommand;
+    }
+    let rest = rest.trim_start_matches(' ');
+    if code.is_empty() {
+        return PassResult::Invalid;
+    }
+    let Some(after) = rest.strip_prefix(code) else {
+        return PassResult::Invalid;
+    };
+    // Un espace doit séparer l'ancien code du nouveau (p[clen] == ' ').
+    if !after.starts_with(' ') {
+        return PassResult::Invalid;
+    }
+    let after = after.trim_start_matches(' ');
+    let newcode: String = after
+        .chars()
+        .take_while(|&c| c != ' ' && c != '\r' && c != '\n')
+        .take(CODE_MAXLEN)
+        .collect();
+    if newcode.is_empty() {
+        PassResult::Invalid
+    } else {
+        PassResult::Ok(newcode)
+    }
+}
+
+/// Résultat de l'analyse de « #b <n> ».
+#[derive(Debug, PartialEq, Eq)]
+pub enum BeepResult {
+    /// Ce n'est pas la commande `#b`.
+    NotCommand,
+    /// Commande `#b` mais valeur hors plage / absente.
+    Invalid,
+    /// Nombre de répétitions accepté (0–BEEP_MAX).
+    Ok(i64),
+}
+
+/// Analyse « #b <n> » → nombre de répétitions (0 = continu, plage 0–BEEP_MAX).
+pub fn parse_beeps(text: &str) -> BeepResult {
+    let t = text.trim_start_matches(' ');
+    let Some(rest) = t.strip_prefix(BEEP_PREFIX) else {
+        return BeepResult::NotCommand;
+    };
+    if !rest.starts_with(' ') {
+        return BeepResult::NotCommand;
+    }
+    let rest = rest.trim_start_matches(' ');
+    let digits: String = rest.chars().take_while(|c| c.is_ascii_digit()).collect();
+    if digits.is_empty() {
+        return BeepResult::Invalid;
+    }
+    match digits.parse::<i64>() {
+        Ok(n) if (0..=BEEP_MAX).contains(&n) => BeepResult::Ok(n),
+        _ => BeepResult::Invalid,
+    }
+}
+
+// ── Persistance (table `settings`) ──────────────────────────────────────────
+fn load_code(pool: &db::DbPool) -> String {
+    db::get_setting(pool, K_CODE).unwrap_or_else(|| DEFAULT_CODE.to_string())
+}
+fn load_beeps(pool: &db::DbPool) -> i64 {
+    db::get_setting(pool, K_BEEPS)
+        .and_then(|s| s.parse::<i64>().ok())
+        .filter(|n| (0..=BEEP_MAX).contains(n))
+        .unwrap_or(DEFAULT_BEEPS)
+}
+
+/// Envoie un accusé de réception LXMF (texte court) à l'expéditeur.
+/// Aucun `.await` n'est effectué tant que le verrou `lxmf` est tenu.
+fn send_reply(state: &AppState, source_hash: &str, identity_id: &str, reply: &str) {
+    if let Ok(mut lxmf) = state.lxmf.lock() {
+        if let Some(mgr) = lxmf.as_mut() {
+            mgr.send_message(source_hash, reply, "RASEC", &state.db, identity_id);
+        }
+    }
+}
+
+/// Analyse un message LXMF entrant et exécute l'action RASEC-ALERT associée
+/// (déclenchement de l'alerte UI + ACK, ou commande de configuration + ACK).
+///
+/// À appeler depuis le pipeline `process_inbound_lxmf`, après l'enregistrement
+/// et l'émission normale du message : l'alerte s'ajoute à l'affichage du
+/// message dans la conversation, elle ne le remplace pas.
+pub async fn handle_incoming(
+    state: &Arc<AppState>,
+    content: &str,
+    source_hash: &str,
+    identity_id: &str,
+) {
+    // Fast-path : toutes les commandes RASEC commencent par '#'. Évite une
+    // lecture NVS/SQLite pour la grande majorité des messages ordinaires.
+    if !content.trim_start().starts_with('#') {
+        return;
+    }
+
+    // Lecture de l'état persisté hors du thread async.
+    let pool = state.db.clone();
+    let (code, beeps) = db::spawn_db(pool, move |p| (load_code(&p), load_beeps(&p)))
+        .await
+        .unwrap_or_else(|_| (DEFAULT_CODE.to_string(), DEFAULT_BEEPS));
+
+    // 1) Changement de code : « #rapass <ancien> <nouveau> ».
+    match parse_pass(content, &code) {
+        PassResult::Ok(newcode) => {
+            let pool = state.db.clone();
+            let newcode_for_db = newcode.clone();
+            let _ = db::spawn_db(pool, move |p| {
+                db::set_setting(&p, K_CODE, &newcode_for_db);
+            })
+            .await;
+            tracing::info!(from = %source_hash, "RASEC-ALERT: code d'activation mis a jour");
+            send_reply(state, source_hash, identity_id, PASS_ACK);
+            return;
+        }
+        PassResult::Invalid => {
+            tracing::warn!(from = %source_hash, "RASEC-ALERT: #rapass refuse (ancien code faux)");
+            send_reply(state, source_hash, identity_id, PASS_FAIL);
+            return;
+        }
+        PassResult::NotCommand => {}
+    }
+
+    // 2) Réglage des répétitions : « #b <n> ».
+    match parse_beeps(content) {
+        BeepResult::Ok(n) => {
+            let pool = state.db.clone();
+            let _ = db::spawn_db(pool, move |p| {
+                db::set_setting(&p, K_BEEPS, &n.to_string());
+            })
+            .await;
+            let reply = if n == 0 {
+                "Alarme continue (acquit. a l'ecran)".to_string()
+            } else {
+                format!("Repetitions reglees sur {n}")
+            };
+            tracing::info!(from = %source_hash, beeps = n, "RASEC-ALERT: repetitions reglees");
+            send_reply(state, source_hash, identity_id, &reply);
+            return;
+        }
+        BeepResult::Invalid => {
+            let reply = format!("Valeur #b invalide (0-{BEEP_MAX})");
+            send_reply(state, source_hash, identity_id, &reply);
+            return;
+        }
+        BeepResult::NotCommand => {}
+    }
+
+    // 3) Déclencheur d'alerte : « #ra <code> ».
+    if match_code(content, &code) {
+        tracing::warn!(from = %source_hash, beeps, "RASEC-ALERT: alerte declenchee");
+
+        // Signale l'UI (overlay + sirène). Le webview joue la sirène pour
+        // `beeps` cycles (0 = continu jusqu'à acquittement).
+        state.emit_to_all(
+            "rasec_alert",
+            json!({
+                "beeps": beeps,
+                "source": source_hash,
+                "version": RASEC_ALERT_VERSION,
+            }),
+        );
+
+        // Notification native (utile si l'app est en arrière-plan / mobile).
+        let label = crate::contact_label_from_db(&state.db, source_hash, identity_id);
+        state.emit_native_notification(ratspeak_core::NativeNotification::message(
+            "RASEC ALERT".to_string(),
+            format!("Alerte declenchee par {label}"),
+            format!("lxmf:{source_hash}"),
+            0,
+        ));
+
+        // ACK automatique (sans le code : anti-boucle).
+        send_reply(state, source_hash, identity_id, ACK_TEXT);
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    const CODE: &str = "ADRASEC77";
+
+    #[test]
+    fn match_code_accepts_exact_and_trailing() {
+        assert!(match_code("#ra ADRASEC77", CODE));
+        assert!(match_code("   #ra   ADRASEC77", CODE));
+        assert!(match_code("#ra ADRASEC77 ", CODE));
+        assert!(match_code("#ra ADRASEC77\r\n", CODE));
+    }
+
+    #[test]
+    fn match_code_rejects_wrong_or_partial() {
+        assert!(!match_code("#ra WRONG", CODE));
+        assert!(!match_code("#ra ADRASEC77EXTRA", CODE));
+        assert!(!match_code("#ra", CODE));
+        assert!(!match_code("hello world", CODE));
+        // Le préfixe de #rapass ne doit pas déclencher l'alerte.
+        assert!(!match_code("#rapass ADRASEC77 NEW", CODE));
+    }
+
+    #[test]
+    fn parse_pass_changes_code() {
+        assert_eq!(
+            parse_pass("#rapass ADRASEC77 NOUVEAU", CODE),
+            PassResult::Ok("NOUVEAU".to_string())
+        );
+        assert_eq!(parse_pass("#rapass WRONG NEW", CODE), PassResult::Invalid);
+        assert_eq!(parse_pass("#rapass ADRASEC77 ", CODE), PassResult::Invalid);
+        assert_eq!(parse_pass("#ra ADRASEC77", CODE), PassResult::NotCommand);
+        assert_eq!(parse_pass("#rapassX", CODE), PassResult::NotCommand);
+    }
+
+    #[test]
+    fn parse_beeps_range() {
+        assert_eq!(parse_beeps("#b 0"), BeepResult::Ok(0));
+        assert_eq!(parse_beeps("#b 5"), BeepResult::Ok(5));
+        assert_eq!(parse_beeps("#b 20"), BeepResult::Ok(20));
+        assert_eq!(parse_beeps("#b 21"), BeepResult::Invalid);
+        assert_eq!(parse_beeps("#b x"), BeepResult::Invalid);
+        assert_eq!(parse_beeps("#ra ADRASEC77"), BeepResult::NotCommand);
+        assert_eq!(parse_beeps("#beep"), BeepResult::NotCommand);
+    }
+}
